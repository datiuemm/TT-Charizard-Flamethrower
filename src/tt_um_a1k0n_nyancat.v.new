    rom_fire[16354] = 'hx;
    rom_fire[16355] = 'hx;
    rom_fire[16356] = 'hx;
    rom_fire[16357] = 'hx;
    rom_fire[16358] = 'hx;
    rom_fire[16359] = 'hx;
    rom_fire[16360] = 'hx;
    rom_fire[16361] = 'hx;
    rom_fire[16362] = 'hx;
    rom_fire[16363] = 'hx;
    rom_fire[16364] = 'hx;
    rom_fire[16365] = 'hx;
    rom_fire[16366] = 'hx;
    rom_fire[16367] = 'hx;
    rom_fire[16368] = 'hx;
    rom_fire[16369] = 'hx;
    rom_fire[16370] = 'hx;
    rom_fire[16371] = 'hx;
    rom_fire[16372] = 'hx;
    rom_fire[16373] = 'hx;
    rom_fire[16374] = 'hx;
    rom_fire[16375] = 'hx;
    rom_fire[16376] = 'hx;
    rom_fire[16377] = 'hx;
    rom_fire[16378] = 'hx;
    rom_fire[16379] = 'hx;
    rom_fire[16380] = 'hx;
    rom_fire[16381] = 'hx;
    rom_fire[16382] = 'hx;
    rom_fire[16383] = 'hx;
    pal_r[0] = 'h0c;
    pal_r[1] = 'h0c;
    pal_r[2] = 'h00;
    pal_r[3] = 'h0b;
    pal_r[4] = 'h00;
    pal_r[5] = 'h06;
    pal_r[6] = 'h0c;
    pal_r[7] = 'h06;
    pal_g[0] = 'h0c;
    pal_g[1] = 'h0b;
    pal_g[2] = 'h00;
    pal_g[3] = 'h03;
    pal_g[4] = 'h04;
    pal_g[5] = 'h05;
    pal_g[6] = 'h0a;
    pal_g[7] = 'h00;
    pal_b[0] = 'h0c;
    pal_b[1] = 'h06;
    pal_b[2] = 'h00;
    pal_b[3] = 'h00;
    pal_b[4] = 'h07;
    pal_b[5] = 'h03;
    pal_b[6] = 'h00;
    pal_b[7] = 'h00;
    end

    // --- ANIMATION & RAIN LFSR ---
    reg [7:0] frame_count;
    reg [2:0] nyanframe;
    reg [6:0] line_lfsr;
    wire [6:0] line_lfsr_next = {line_lfsr[0], line_lfsr[0]^line_lfsr[6], line_lfsr[5:1]};

    // --- RENDERING LOGIC ---
    // Giảm bớt các phép tính tọa độ phức tạp
    wire [13:0] addr = {nyanframe, (pix_y[7:3] - 5'd18), (pix_x[8:3] - 6'd8)};
    reg [2:0] idx;

    always @* begin
        // Chỉ vẽ khi nằm trong vùng hiển thị của Fire và nút được bấm
        if (is_firing && (pix_x >= 64 && pix_x < 512) && (pix_y >= 144 && pix_y < 400)) begin
            idx = rom_fire[addr];
        end else begin
            idx = 0;
        end
    end

    // --- RAIN LOGIC ---
    wire [9:0] rain_y = pix_y - (frame_count << 1);
    wire rain = (idx == 0) && (pix_x[6:1] == line_lfsr[6:1]) && (rain_y[5:0] < 12);

    // --- MAIN CONTROL BLOCK ---
    always @(posedge clk or negedge rst_n) begin
        if (~rst_n) begin
            frame_count <= 0; 
            nyanframe <= 0; 
            line_lfsr <= 7'h5a;
        end else begin
            if (pix_x == 0 && pix_y == 0) begin
                frame_count <= frame_count + 1;
                if (frame_count[1:0] == 0) 
                    nyanframe <= (nyanframe == 5) ? 0 : nyanframe + 1;
                line_lfsr <= 7'h5a;
            end else if (pix_x == 0 && pix_y[3:0] == 0) begin
                line_lfsr <= line_lfsr_next;
            end

            // --- COLOR OUTPUT ---
            if (video_active) begin
                if (idx != 0) begin
                    R <= pal_r[idx][3:2]; G <= pal_g[idx][3:2]; B <= pal_b[idx][3:2];
                end else if (rain) begin
                    R <= 2'b10; G <= 2'b10; B <= 2'b11; // Hạt mưa
                end else begin
                    // Background đơn giản: Trời & Đất
                    if (pix_y < 350) begin
                        R <= 2'b00; G <= 2'b00; B <= 2'b01; // Sky
                    end else begin
                        R <= 2'b00; G <= 2'b01; B <= 2'b00; // Grass
                    end
                end
            end else begin
                {R, G, B} <= 6'b0;
            end
        end
    end

    // Unused ports
    assign uio_out = 8'b0; 
    assign uio_oe = 8'b0;
    wire _unused = &{ena, ui_in, uio_in};

endmodule
